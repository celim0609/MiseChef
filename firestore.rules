rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDocument(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return signedIn()
        && (
          request.auth.token.email == 'celim0609@gmail.com'
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
          )
        );
    }

    function currentCompanyId() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId
        : null;
    }

    function currentCompanyRole() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyRole
        : null;
    }

    function isCurrentCompany(companyId) {
      return signedIn() && currentCompanyId() == companyId;
    }

    function isCompanyOwnerOrManager(companyId) {
      return isSuperAdmin()
        || (isCurrentCompany(companyId) && currentCompanyRole() in ['owner', 'manager']);
    }

    function preservesOrBackfillsDefaultSubscriptionFields() {
      return (
          ('subscriptionPlan' in resource.data && request.resource.data.subscriptionPlan == resource.data.subscriptionPlan)
          || (!('subscriptionPlan' in resource.data) && request.resource.data.subscriptionPlan == 'free')
        )
        && (
          ('subscriptionStatus' in resource.data && request.resource.data.subscriptionStatus == resource.data.subscriptionStatus)
          || (!('subscriptionStatus' in resource.data) && request.resource.data.subscriptionStatus == 'active')
        )
        && (
          ('billingCycle' in resource.data && request.resource.data.billingCycle == resource.data.billingCycle)
          || (!('billingCycle' in resource.data) && request.resource.data.billingCycle == 'monthly')
        )
        && (
          ('subscriptionStartedAt' in resource.data && request.resource.data.subscriptionStartedAt == resource.data.subscriptionStartedAt)
          || !('subscriptionStartedAt' in resource.data)
        )
        && (
          ('subscriptionRenewalAt' in resource.data && request.resource.data.subscriptionRenewalAt == resource.data.subscriptionRenewalAt)
          || (!('subscriptionRenewalAt' in resource.data) && request.resource.data.subscriptionRenewalAt == '')
        )
        && (
          ('subscriptionCancelledAt' in resource.data && request.resource.data.subscriptionCancelledAt == resource.data.subscriptionCancelledAt)
          || (!('subscriptionCancelledAt' in resource.data) && request.resource.data.subscriptionCancelledAt == null)
        );
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.createdBy == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    function ownsExistingUserData() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingUserData() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function existingWorkspaceId() {
      return ('workspaceId' in resource.data)
        ? resource.data.workspaceId
        : (('createdBy' in resource.data) ? resource.data.createdBy : resource.data.userId);
    }

    function incomingWorkspaceId() {
      return ('workspaceId' in request.resource.data)
        ? request.resource.data.workspaceId
        : (('createdBy' in request.resource.data) ? request.resource.data.createdBy : request.resource.data.userId);
    }

    function workspaceMemberId(workspaceId) {
      return workspaceId + "_" + request.auth.uid;
    }

    function isWorkspaceMember(workspaceId) {
      return isSuperAdmin()
        || (signedIn()
          && (workspaceId == request.auth.uid
            || (exists(/databases/$(database)/documents/workspaceMembers/$(workspaceMemberId(workspaceId)))
              && get(/databases/$(database)/documents/workspaceMembers/$(workspaceMemberId(workspaceId))).data.status == 'Active')));
    }

    function currentWorkspaceRole(workspaceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/workspaceMembers/$(workspaceMemberId(workspaceId)))
        ? get(/databases/$(database)/documents/workspaceMembers/$(workspaceMemberId(workspaceId))).data.role
        : null;
    }

    function hasWorkspaceRole(workspaceId, roles) {
      return isSuperAdmin()
        || (isWorkspaceMember(workspaceId) && currentWorkspaceRole(workspaceId) in roles);
    }

    function isWorkspaceOwner(workspaceId) {
      return isSuperAdmin() || hasWorkspaceRole(workspaceId, ['Owner']);
    }

    function isWorkspaceOwnerOrManager(workspaceId) {
      return isSuperAdmin() || hasWorkspaceRole(workspaceId, ['Owner', 'Manager']);
    }

    function isWorkspaceManagerLevel(workspaceId) {
      return isSuperAdmin() || hasWorkspaceRole(workspaceId, ['Owner', 'Manager', 'Head Chef']);
    }

    function hasProfessionalWorkspaceEntitlement(workspaceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/companies/$(workspaceId))
        && get(/databases/$(database)/documents/companies/$(workspaceId)).data.subscriptionStatus in ['active', 'trialing']
        && get(/databases/$(database)/documents/companies/$(workspaceId)).data.subscriptionPlan in ['professional', 'business', 'enterprise'];
    }

    function canAccessRecipes(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['Owner', 'Manager', 'Head Chef', 'Sous Chef', 'Chef']);
    }

    function canAccessInvoices(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['Owner', 'Manager', 'Head Chef', 'Purchasing']);
    }

    function canAccessSuppliers(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['Owner', 'Manager', 'Head Chef', 'Purchasing']);
    }

    function canAccessBusiness(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['Owner', 'Manager', 'Head Chef', 'Finance'])
        && hasProfessionalWorkspaceEntitlement(workspaceId);
    }

    function canInviteTeam(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['Owner', 'Manager', 'Head Chef'])
        && hasProfessionalWorkspaceEntitlement(workspaceId);
    }

    function hasValidRecommendedProductIds() {
      return !('recommendedProductIds' in request.resource.data)
        || (request.resource.data.recommendedProductIds is list
          && request.resource.data.recommendedProductIds.size() <= 100);
    }

    function isValidCreatorCode(code) {
      return code is string && code.matches('^MC[0-9]{3,6}$');
    }

    function activeCreatorProfileExists(code) {
      return isValidCreatorCode(code)
        && exists(/databases/$(database)/documents/creatorAffiliateProfiles/$(code))
        && get(/databases/$(database)/documents/creatorAffiliateProfiles/$(code)).data.active == true;
    }

    function authenticatedCreatorMatches(code, workspaceId) {
      return signedIn()
        && activeCreatorProfileExists(code)
        && get(/databases/$(database)/documents/creatorAffiliateProfiles/$(code)).data.userId == request.auth.uid
        && currentWorkspaceRole(workspaceId) == 'Chef';
    }

    function sameRecommendedProductIds() {
      return (
          !('recommendedProductIds' in resource.data)
          && !('recommendedProductIds' in request.resource.data)
        )
        || (
          'recommendedProductIds' in resource.data
          && 'recommendedProductIds' in request.resource.data
          && request.resource.data.recommendedProductIds == resource.data.recommendedProductIds
        );
    }

    function onlyRemovesRecommendedProductIds() {
      return 'recommendedProductIds' in resource.data
        && 'recommendedProductIds' in request.resource.data
        && resource.data.recommendedProductIds is list
        && request.resource.data.recommendedProductIds is list
        && request.resource.data.recommendedProductIds.size() < resource.data.recommendedProductIds.size()
        && request.resource.data.recommendedProductIds.toSet().hasOnly(resource.data.recommendedProductIds.toSet());
    }

    function sameAffiliateCreatorCode() {
      return (
          !('affiliateCreatorCode' in resource.data)
          && !('affiliateCreatorCode' in request.resource.data)
        )
        || (
          'affiliateCreatorCode' in resource.data
          && 'affiliateCreatorCode' in request.resource.data
          && request.resource.data.affiliateCreatorCode == resource.data.affiliateCreatorCode
        );
    }

    function hasValidCreatorAttributionOnCreate() {
      return (
          (
            !('recommendedProductIds' in request.resource.data)
            || request.resource.data.recommendedProductIds.size() == 0
          )
          && !('affiliateCreatorCode' in request.resource.data)
        )
        || (
          'recommendedProductIds' in request.resource.data
          && request.resource.data.recommendedProductIds.size() > 0
          && 'affiliateCreatorCode' in request.resource.data
          && (
            authenticatedCreatorMatches(request.resource.data.affiliateCreatorCode, incomingWorkspaceId())
            || (isSuperAdmin() && activeCreatorProfileExists(request.resource.data.affiliateCreatorCode))
          )
        );
    }

    function hasValidCreatorAttributionOnUpdate() {
      return (
          sameRecommendedProductIds()
          && sameAffiliateCreatorCode()
        )
        || (
          onlyRemovesRecommendedProductIds()
          && sameAffiliateCreatorCode()
        )
        || (
          !sameRecommendedProductIds()
          && !onlyRemovesRecommendedProductIds()
          && 'affiliateCreatorCode' in request.resource.data
          && authenticatedCreatorMatches(request.resource.data.affiliateCreatorCode, existingWorkspaceId())
          && (
            !('affiliateCreatorCode' in resource.data)
            || request.resource.data.affiliateCreatorCode == resource.data.affiliateCreatorCode
          )
        )
        || (
          isSuperAdmin()
          && 'affiliateCreatorCode' in request.resource.data
          && activeCreatorProfileExists(request.resource.data.affiliateCreatorCode)
        );
    }

    function doesNotCreateLegacyRecommendations() {
      return !('recommendedProducts' in request.resource.data);
    }

    function preservesOrRemovesLegacyRecommendations() {
      return !('recommendedProducts' in resource.data)
        ? !('recommendedProducts' in request.resource.data)
        : (!('recommendedProducts' in request.resource.data)
          || (request.resource.data.recommendedProducts is list
            && request.resource.data.recommendedProducts.toSet().hasOnly(resource.data.recommendedProducts.toSet())));
    }

    function isValidApprovedProduct() {
      return request.resource.data.keys().hasOnly([
          'name',
          'imageUrl',
          'affiliateUrl',
          'merchantHostname',
          'active',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 160
        && request.resource.data.affiliateUrl is string
        && request.resource.data.affiliateUrl.matches('^https://s[.]shopee[.]sg/.*$')
        && request.resource.data.affiliateUrl.size() <= 2048
        && request.resource.data.merchantHostname == 's.shopee.sg'
        && request.resource.data.active is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.createdBy is string
        && request.resource.data.updatedBy is string
        && (!('imageUrl' in request.resource.data)
          || (request.resource.data.imageUrl is string && request.resource.data.imageUrl.size() <= 2048));
    }

    function isValidCreatorProfile(creatorCode) {
      return isValidCreatorCode(creatorCode)
        && request.resource.data.keys().hasOnly([
          'creatorCode',
          'userId',
          'active',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy'
        ])
        && request.resource.data.creatorCode == creatorCode
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0
        && request.resource.data.active is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.createdBy is string
        && request.resource.data.updatedBy is string;
    }

    function isValidCreatorProductLink(creatorCode, productId) {
      return request.resource.data.keys().hasOnly([
          'creatorCode',
          'productId',
          'affiliateUrl',
          'merchantHostname',
          'active',
          'verifiedAt',
          'verifiedBy',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy'
        ])
        && request.resource.data.creatorCode == creatorCode
        && request.resource.data.productId == productId
        && request.resource.data.affiliateUrl is string
        && request.resource.data.affiliateUrl.matches('^https://s[.]shopee[.]sg/.*$')
        && request.resource.data.affiliateUrl.size() <= 2048
        && request.resource.data.merchantHostname == 's.shopee.sg'
        && request.resource.data.active is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.createdBy is string
        && request.resource.data.updatedBy is string
        && (
          request.resource.data.active == false
          || (
            request.resource.data.verifiedAt is timestamp
            && request.resource.data.verifiedBy is string
            && request.resource.data.verifiedBy.size() > 0
          )
        );
    }

    function isArchivedInvoiceWrite() {
      return request.resource.data.processingStatus == 'Archived'
        || request.resource.data.status == 'Archived';
    }

    match /users/{userId} {
      allow read: if ownsUserDocument(userId) || isSuperAdmin();
      allow create, update, delete: if ownsUserDocument(userId);

      match /portfolio/{document=**} {
        allow read, create, update, delete: if ownsUserDocument(userId);
      }
    }

    match /companies/{companyId} {
      allow create: if signedIn()
        && request.resource.data.companyId == companyId
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.subscriptionPlan == 'free'
        && request.resource.data.subscriptionStatus == 'active'
        && request.resource.data.billingCycle == 'monthly';
      allow read: if isSuperAdmin() || isCurrentCompany(companyId) || resource.data.ownerId == request.auth.uid || isWorkspaceMember(companyId);
      allow update: if (isSuperAdmin() || ((isCompanyOwnerOrManager(companyId) || resource.data.ownerId == request.auth.uid) && preservesOrBackfillsDefaultSubscriptionFields()))
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if false;
    }

    match /recipes/{recipeId} {
      allow create: if ownsIncomingUserData()
        && canAccessRecipes(incomingWorkspaceId())
        && hasValidRecommendedProductIds()
        && hasValidCreatorAttributionOnCreate()
        && doesNotCreateLegacyRecommendations();
      allow read: if canAccessRecipes(existingWorkspaceId());
      allow delete: if canAccessRecipes(existingWorkspaceId());
      allow update: if canAccessRecipes(existingWorkspaceId())
        && (!('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId)
        && incomingWorkspaceId() == existingWorkspaceId()
        && hasValidRecommendedProductIds()
        && hasValidCreatorAttributionOnUpdate()
        && preservesOrRemovesLegacyRecommendations();
    }

    match /approvedProducts/{productId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin()
        && isValidApprovedProduct()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow update: if isSuperAdmin()
        && isValidApprovedProduct()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if false;
    }

    match /creatorAffiliateProfiles/{creatorCode} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin()
        && isValidCreatorProfile(creatorCode)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow update: if isSuperAdmin()
        && isValidCreatorProfile(creatorCode)
        && request.resource.data.creatorCode == resource.data.creatorCode
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if false;

      match /productLinks/{productId} {
        allow read: if isSuperAdmin();
        allow create: if isSuperAdmin()
          && isValidCreatorProductLink(creatorCode, productId)
          && request.resource.data.active == false
          && !('verifiedAt' in request.resource.data)
          && !('verifiedBy' in request.resource.data)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedBy == request.auth.uid;
        allow update: if isSuperAdmin()
          && isValidCreatorProductLink(creatorCode, productId)
          && request.resource.data.creatorCode == resource.data.creatorCode
          && request.resource.data.productId == resource.data.productId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.updatedBy == request.auth.uid
          && (
            request.resource.data.affiliateUrl == resource.data.affiliateUrl
            || (
              request.resource.data.active == false
              && !('verifiedAt' in request.resource.data)
              && !('verifiedBy' in request.resource.data)
            )
          )
          && (
            request.resource.data.active == false
            || (
              request.resource.data.verifiedBy == request.auth.uid
              && request.resource.data.verifiedAt is timestamp
            )
          );
        allow delete: if false;
      }
    }

    match /publicRecipes/{recipeId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /publicProductClicks/{clickId} {
      allow read, write: if false;
    }

    match /publicRecipeProductRedirects/{recipeId} {
      allow read, write: if false;
    }

    match /categories/{categoryId} {
      allow create: if ownsIncomingUserData() && canAccessRecipes(incomingWorkspaceId());
      allow read, delete: if canAccessRecipes(existingWorkspaceId());
      allow update: if canAccessRecipes(existingWorkspaceId())
        && (!('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId)
        && incomingWorkspaceId() == existingWorkspaceId();
    }

    match /invoices/{invoiceId} {
      allow create: if false;
      allow read: if canAccessInvoices(existingWorkspaceId());
      allow update: if canAccessInvoices(existingWorkspaceId())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.id == resource.data.id
        && request.resource.data.fileName == resource.data.fileName
        && request.resource.data.fileType == resource.data.fileType
        && request.resource.data.size == resource.data.size
        && request.resource.data.uploadDate == resource.data.uploadDate
        && (
          ('storageFileName' in resource.data && request.resource.data.storageFileName == resource.data.storageFileName)
          || (!('storageFileName' in resource.data) && !('storageFileName' in request.resource.data))
        )
        && incomingWorkspaceId() == existingWorkspaceId()
        && (!isArchivedInvoiceWrite() || isWorkspaceOwnerOrManager(existingWorkspaceId()));
      allow delete: if isWorkspaceOwnerOrManager(existingWorkspaceId());
    }

    match /ingredients/{ingredientId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == ingredientId
        && canAccessInvoices(incomingWorkspaceId())
        && request.resource.data.status == 'Active';
      allow read: if canAccessInvoices(existingWorkspaceId());
      allow update: if canAccessInvoices(existingWorkspaceId())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.id == resource.data.id;
      allow delete: if isWorkspaceOwnerOrManager(existingWorkspaceId());
    }

    match /ingredientPriceHistory/{historyId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == historyId
        && canAccessInvoices(incomingWorkspaceId());
      allow read: if canAccessInvoices(existingWorkspaceId());
      allow update: if canAccessInvoices(existingWorkspaceId())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }

    match /invoiceAuditLogs/{auditId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == auditId
        && isWorkspaceMember(incomingWorkspaceId());
      allow read: if isWorkspaceMember(existingWorkspaceId());
      allow update, delete: if false;
    }

    match /recipeCostRecalculations/{recalculationId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == recalculationId
        && canAccessInvoices(incomingWorkspaceId())
        && request.resource.data.status == 'Pending';
      allow read: if canAccessInvoices(existingWorkspaceId());
      allow update: if canAccessInvoices(existingWorkspaceId())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }


    match /suppliers/{supplierId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == supplierId
        && canAccessSuppliers(incomingWorkspaceId())
        && request.resource.data.status == 'Active';
      allow read: if canAccessSuppliers(existingWorkspaceId());
      allow update: if canAccessSuppliers(existingWorkspaceId())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.id == resource.data.id
        && request.resource.data.status in ['Active', 'Archived'];
      allow delete: if false;
    }


    match /supplierQuotations/{quotationId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == quotationId
        && canAccessSuppliers(incomingWorkspaceId());
      allow read: if canAccessSuppliers(existingWorkspaceId());
      allow update: if canAccessSuppliers(existingWorkspaceId())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }

    match /quotations/{quotationId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == quotationId
        && canAccessSuppliers(incomingWorkspaceId());
      allow read: if canAccessSuppliers(existingWorkspaceId());
      allow update: if canAccessSuppliers(existingWorkspaceId())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }

    match /businessSales/{saleId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == saleId
        && canAccessBusiness(incomingWorkspaceId());
      allow read: if canAccessBusiness(existingWorkspaceId());
      allow update: if canAccessBusiness(existingWorkspaceId())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if signedIn()
        && isWorkspaceMember(request.resource.data.workspaceId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.type == 'personal'
        && request.resource.data.completed == false
        && request.resource.data.completedAt == null
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.keys().hasOnly([
          'type',
          'title',
          'completed',
          'workspaceId',
          'createdBy',
          'createdAt',
          'completedAt'
        ]);
      allow update: if isWorkspaceMember(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.type == resource.data.type
        && request.resource.data.title == resource.data.title
        && request.resource.data.createdAt == resource.data.createdAt
        && resource.data.completed == false
        && request.resource.data.completed == true
        && request.resource.data.completedAt is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completed', 'completedAt']);
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      allow create: if signedIn()
        && request.resource.data.id == workspaceId
        && request.resource.data.ownerId == request.auth.uid
        && (workspaceId == request.auth.uid || isSuperAdmin());
      allow read: if isWorkspaceMember(workspaceId);
      allow update: if (isWorkspaceOwner(workspaceId) || (isWorkspaceOwnerOrManager(workspaceId) && request.resource.data.ownerId == resource.data.ownerId))
        && request.resource.data.id == resource.data.id;
      allow delete: if false;

      match /portfolio/{portfolioId} {
        allow read, create, update: if isWorkspaceMember(workspaceId);
        allow delete: if false;
      }
    }

    match /publicChefProfiles/{username} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /publicChefProfileOwnership/{username} {
      allow read, create, update, delete: if false;
    }

    match /chefEnquiries/{enquiryId} {
      allow create: if request.resource.data.keys().hasOnly([
          'username',
          'name',
          'email',
          'message',
          'createdAt',
          'status'
        ])
        && request.resource.data.username is string
        && exists(/databases/$(database)/documents/publicChefProfileOwnership/$(request.resource.data.username))
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.createdAt is string
        && request.resource.data.status == 'New';
      allow read: if signedIn()
        && get(/databases/$(database)/documents/publicChefProfileOwnership/$(resource.data.username)).data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }

    match /workspaceMembers/{memberId} {
      allow create: if signedIn()
        && request.resource.data.id == memberId
        && request.resource.data.status == 'Active'
        && (
          (request.resource.data.userId == request.auth.uid
            && request.resource.data.role == 'Owner'
            && existsAfter(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId))
            && getAfter(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)).data.ownerId == request.auth.uid)
          || (canInviteTeam(request.resource.data.workspaceId) && request.resource.data.userId != request.auth.uid)
          || (request.resource.data.userId == request.auth.uid
            && 'invitationId' in request.resource.data
            && hasProfessionalWorkspaceEntitlement(request.resource.data.workspaceId)
            && exists(/databases/$(database)/documents/teamInvitations/$(request.resource.data.invitationId))
            && get(/databases/$(database)/documents/teamInvitations/$(request.resource.data.invitationId)).data.workspaceId == request.resource.data.workspaceId
            && get(/databases/$(database)/documents/teamInvitations/$(request.resource.data.invitationId)).data.email == request.auth.token.email
            && get(/databases/$(database)/documents/teamInvitations/$(request.resource.data.invitationId)).data.status == 'Pending'
            && request.resource.data.role == get(/databases/$(database)/documents/teamInvitations/$(request.resource.data.invitationId)).data.role)
        );
      allow read: if resource.data.userId == request.auth.uid
        || (isWorkspaceManagerLevel(resource.data.workspaceId) && hasProfessionalWorkspaceEntitlement(resource.data.workspaceId));
      allow update: if isWorkspaceManagerLevel(resource.data.workspaceId)
        && hasProfessionalWorkspaceEntitlement(resource.data.workspaceId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.userId == resource.data.userId
        && (resource.data.role != 'Owner' || isWorkspaceOwner(resource.data.workspaceId));
      allow delete: if false;
    }

    match /roles/{roleId} {
      allow create: if ownsIncomingDocument()
        && request.resource.data.id == roleId
        && hasProfessionalWorkspaceEntitlement(request.resource.data.workspaceId);
      allow read: if isWorkspaceManagerLevel(resource.data.workspaceId)
        && hasProfessionalWorkspaceEntitlement(resource.data.workspaceId);
      allow update: if isWorkspaceOwner(resource.data.workspaceId)
        && hasProfessionalWorkspaceEntitlement(resource.data.workspaceId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.workspaceId == resource.data.workspaceId;
      allow delete: if false;
    }


    match /teamInvitations/{invitationId} {
      allow create: if signedIn()
        && request.resource.data.id == invitationId
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'Pending'
        && canInviteTeam(request.resource.data.workspaceId)
        && request.resource.data.role in ['Manager', 'Head Chef', 'Sous Chef', 'Chef', 'Purchasing', 'Finance', 'Viewer'];
      allow read: if (isWorkspaceManagerLevel(resource.data.workspaceId)
          && hasProfessionalWorkspaceEntitlement(resource.data.workspaceId))
        || resource.data.email == request.auth.token.email;
      allow update: if (isWorkspaceManagerLevel(resource.data.workspaceId)
        && hasProfessionalWorkspaceEntitlement(resource.data.workspaceId))
        || (signedIn()
          && resource.data.email == request.auth.token.email
          && resource.data.status == 'Pending'
          && request.resource.data.workspaceId == resource.data.workspaceId
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && (
            (request.resource.data.status == 'Accepted'
              && request.resource.data.acceptedBy == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'acceptedBy', 'updatedAt']))
            || (request.resource.data.status == 'Declined'
              && request.resource.data.declinedBy == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'declinedAt', 'declinedBy', 'updatedAt']))
          ));
      allow delete: if false;
    }

    match /teamAuditLogs/{auditId} {
      allow create: if signedIn()
        && request.resource.data.performedBy == request.auth.uid
        && isWorkspaceMember(request.resource.data.workspaceId);
      allow read: if isWorkspaceManagerLevel(resource.data.workspaceId) || isSuperAdmin();
      allow update, delete: if false;
    }

    match /enquiries/{enquiryId} {
      allow create: if request.resource.data.keys().hasOnly([
          'name',
          'company',
          'email',
          'phone',
          'country',
          'businessType',
          'outletCount',
          'message',
          'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.company is string
        && request.resource.data.email is string
        && request.resource.data.createdAt is string;
      allow read: if isSuperAdmin() || isWorkspaceMember(resource.data.companyId);
      allow update, delete: if false;
    }

    match /ai_usage/{usageId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId',
          'companyId',
          'feature',
          'provider',
          'model',
          'promptTokens',
          'completionTokens',
          'totalTokens',
          'estimatedCostUSD',
          'responseTime',
          'status',
          'createdAt'
        ]);
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /audit_logs/{auditId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'timestamp',
          'userId',
          'companyId',
          'userRole',
          'action',
          'module',
          'resourceType',
          'resourceId',
          'description',
          'ipAddress',
          'userAgent',
          'status'
        ]);
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /aiUsage/{document=**} {
      allow read, write: if false;
    }

    match /aiRequestLogs/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
